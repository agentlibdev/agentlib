{
  "name": "@agentlibdev/agentlib",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare-first public registry for portable AI agents",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "scripts": {
    "build:test": "tsc -p tsconfig.test.json && node scripts/post-compile-aliases.mjs",
    "test": "npm run build:test && node --test .test-dist/apps/*/test/*.test.js",
    "typecheck": "tsc --noEmit",
    "dev:web": "npm run dev --workspace @agentlibdev/web",
    "build:web": "npm run build --workspace @agentlibdev/web",
    "build:deploy": "npm run build:web",
    "deploy": "npm run build:deploy && wrangler deploy",
    "d1:migrate:local": "wrangler d1 execute DB --local --persist-to .wrangler/state --file migrations/0001_initial.sql --yes",
    "d1:seed:providers:local": "wrangler d1 execute DB --local --persist-to .wrangler/state --file migrations/seed/0001_providers.sql --yes",
    "d1:seed:sample:local": "wrangler d1 execute DB --local --persist-to .wrangler/state --file migrations/seed/0002_sample_agents.sql --yes",
    "d1:reset:local": "rm -rf .wrangler/state && npm run d1:migrate:local && npm run d1:seed:providers:local && npm run d1:seed:sample:local",
    "d1:list:local": "wrangler d1 execute DB --local --persist-to .wrangler/state --command \"SELECT namespace, name, latest_version FROM agents ORDER BY namespace, name;\" --json",
    "d1:list:artifacts:local": "wrangler d1 execute DB --local --persist-to .wrangler/state --command \"SELECT agent_version_id, path, media_type, size_bytes FROM artifacts ORDER BY path;\" --json",
    "dev:api": "wrangler dev",
    "dev:api:local": "wrangler dev --local --persist-to .wrangler/state --port 8787 --ip 127.0.0.1 --show-interactive-dev-session=false --log-level warn",
    "publish:sample:local": "node scripts/publish-sample-local.mjs",
    "publish:example:local": "tsx scripts/publish-example-local.ts",
    "populate:demo:local": "node scripts/populate-demo-local.mjs",
    "import:github:local": "node scripts/import-github-local.mjs",
    "list:artifacts:local": "node scripts/list-artifacts-local.mjs",
    "download:artifact:local": "node scripts/download-artifact-local.mjs",
    "smoke:local": "node scripts/smoke-local.mjs"
  },
  "devDependencies": {
    "@agentlibdev/agent-schema": "file:../agent-schema",
    "@cloudflare/workers-types": "^4.20260305.0",
    "@types/node": "^22.15.30",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "wrangler": "^4.38.0"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "react-markdown": "^10.1.0"
  }
}
