{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "types": [
      "node",
      "@cloudflare/workers-types"
    ],
    "skipLibCheck": true
  },
  "include": [
    "apps/**/*.ts",
    "packages/**/*.ts"
  ]
}
